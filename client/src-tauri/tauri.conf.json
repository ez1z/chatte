{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chatte VPN",
  "version": "0.1.0",
  "identifier": "dev.chatte.vpn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chatte VPN",
        "width": 420,
        "height": 680,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis"],
    "icon": []
  }
}
